@page "/customer/delete/{customerId:int}"
@rendermode InteractiveServer
@inject DataService objService
@inject NavigationManager navigationManager

<PageTitle>Delete Customer</PageTitle>

@if (customer.CustomerId == 0)
{
    <div class="alert alert-info" role="alert">
        <h1>Customer not found.</h1>
    </div>
}
else
{
    <h2>Delete Customer</h2>
    <hr />
    <h3>Do you want to delete <span class="text-danger fw-bold">@customer.Name</span>?</h3>
    <div class="row">
        <div class="col-md-8">
            <div class="form-group">
                <label>Customer Id:</label>
                <label>@customer.CustomerId</label>
            </div>
            <div class="form-group">
                <label>Name:</label>
                <label>@customer.Name</label>
            </div>
            <div class="form-group">
                <label>City:</label>
                <label>@customer.City</label>
            </div>
            <div class="form-group">
                <label>Country:</label>
                <label>@customer.Country</label>
            </div>
            <div class="form-group">
                <label>Gender:</label>
                <label>@customer.Gender</label>
            </div>
        </div>
    </div>
    <div class="row mb-3"></div>
    <div class="row">
        <div class="col-md-4">
            <div class="form-group">
                <input type="button" @onclick="Delete" class="btn btn-danger" value="Delete" />
                <input type="button" @onclick="Cancel" class="btn btn-secondary" value="Cancel" />
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int customerId { get; set; }

    Customer customer = new Customer();

    protected override async Task OnInitializedAsync()
    {
        customer = await Task.Run(() => objService.GetCustomerById(customerId));
    }

    protected void Delete()
    {
        objService.DeleteCustomer(customerId);
        navigationManager.NavigateTo("/customer");
    }

    protected void Cancel()
    {
        navigationManager.NavigateTo("/customer");
    }
}